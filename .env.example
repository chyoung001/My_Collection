# my_collection_backend 환경변수 예시
# 실제 값은 .env(gitignore됨)에 넣고, 배포 환경(Railway 등)에는 플랫폼 환경변수로 설정하세요.
# 복사:  cp .env.example .env   (Windows: copy .env.example .env)

# ── 필수 ──────────────────────────────────────────────
# PostgreSQL 연결 문자열. 미설정 시 서버가 부팅 직후 throw 합니다.
# 관리형 Postgres(SSL 필요)면 ?sslmode=require 를 붙이세요.
DATABASE_URL=postgres://user:password@localhost:5432/my_collection_backenddb

# ── 서버 / 보안 ───────────────────────────────────────
PORT=4000
# production 으로 설정하면 CORS 화이트리스트가 적용되고, API_TOKEN 미설정 시 쓰기를 차단합니다.
NODE_ENV=development
# CORS 허용 출처(쉼표 구분). production 에서만 적용. 예) https://kimchy.github.io
ALLOWED_ORIGINS=
# 쓰기(POST/PATCH/DELETE)와 비용 호출(스크래핑·LLM) 보호용 공유 토큰.
# 설정하면 즉시 활성화 → 클라이언트는 `Authorization: Bearer <token>` 헤더로 전달.
# 강력한 랜덤 값 생성:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=

# ── Swagger ──────────────────────────────────────────
# 배포된 공개 API 베이스 URL(문서의 server 목록에 사용). 없으면 http://localhost:PORT 사용.
PUBLIC_API_BASE_URL=

# ── PSA 인증조회 ─────────────────────────────────────
PSA_API_BASE=https://api.psacard.com/publicapi
PSA_TOKEN=

# ── 시세 스크래핑 (ZenRows) ──────────────────────────
ZENROWS_API_KEY=

# ── LLM (Ollama Cloud, OpenAI 호환) ──────────────────
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=

# ── (레거시) eBay ────────────────────────────────────
# ebayClient.js는 제거되었고 현재는 /api/preferences/health 의 상태 표시에만 참조됩니다.
# 더 이상 쓰지 않으면 이 두 줄과 preferences.js의 참조를 같이 제거하세요.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
